body_rewrites:
- response_jq:
    match: ^https:\/\/adservice\.kugou\.com\/v2\/lite_v_youth_task_center
    filter: del(.data.ads.lite_v_youth_task_center_link[].copywriting)
- response_jq:
    match: ^https:\/\/gateway\.kugou\.com\/youth\/v1\/channel\/tab_list
    filter: .data.list|=map(select((.tab_id==-1or.tab_id==2)|not))
- response_jq:
    match: ^https:\/\/gateway\.kugou\.com\/card\/v1\/pxy
    filter: .data.responses|=map(select(.module!="y_lab"and.module!="y_hot"and.module!="y_song_module_6"and.module!="y_tag"))
- response_jq:
    match: ^https:\/\/gateway\.kugou\.com\/youth\/v1\/account\/get_vip_tips
    filter: .data.account_tips.title="增强无广告"
- response_jq:
    match: ^https:\/\/gateway\.kugou\.com\/youth\/v1\/experiment\/get_params
    filter: .data.olexp_params.flash_ad_show=0|.data.olexp_params.popup_show=0
- response_jq:
