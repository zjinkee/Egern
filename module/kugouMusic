    match: ^https:\/\/gateway\.kugou\.com\/youth\/v1\/ab\/tmeab\?ab_source=SearchListV2
    filter: .data.TMEAB0EarningTab0type.mapParams.Earning_Tab="0"|.data.TMEAB0TaskCenterEnter0type.mapParams.TFC="0"|.data.TMEAB0TaskCenterEnter0type.mapParams.ad="0"|.data.TMEAB0signin0type.mapParams.enter="0"|.data.TMEAB0freesignin0type.mapParams.enter="0"|.data.TMEAB0FreemiumModelTouchpoint0type.mapParams|=with_entries(.value="0")|.data.TMEAB0notpay0splashinterval.mapParams.is_show_up="0"|.data.TMEAB0GNBad0splashexpcontrol.mapParams.front_5s="0"|.data.TMEAB0svipnewguoqiup0Type.mapParams.up_style="0"|.data.TMEAB0wvipguoqiup0Type.mapParams.is_show="0"|.data.TMEAB0vipshellwindow0type.mapParams|=with_entries(.value="0")|.data.TMEAB0fmBidding.mapParams.rewardAdLocalCache="0"|.data.aiwritesong.mapParams.aiwritesong="0"|.data.TMEAB0bofangballchudian0Type.mapParams.is_show="0"
